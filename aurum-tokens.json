        "elevated": {
          "$value": { "dark": "{primitive.neutral.800}", "light": "#FFFFFF" },
          "$type": "color", "$description": "Elevated card / dialog"
        },
        "overlay":  {
          "$value": { "dark": "#28201A", "light": "#F0EAE0" },
          "$type": "color", "$description": "Overlay tint / tooltip bg"
